# ── Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Cal.com booking
NEXT_PUBLIC_CALCOM_BOOKING_URL=https://cal.com/your-team/event-slug

# ── Google OAuth (configured in Supabase Dashboard, not used directly by Next.js)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── LinkedIn OAuth (configured in Supabase Dashboard as Custom OIDC)
# LINKEDIN_CLIENT_ID=your-linkedin-client-id
# LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ── Resend (configured in Supabase Dashboard SMTP settings)
# RESEND_API_KEY=your-resend-api-key
